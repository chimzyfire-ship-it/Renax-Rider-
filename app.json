{
  "expo": {
    "name": "RENAX Rider",
    "displayName": "RENAX Rider",
    "slug": "renax-rider",
    "platforms": ["ios", "android", "web"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "renaxrider",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RENAX Rider uses your location to broadcast your position to dispatchers and customers during active deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RENAX Rider tracks your location in the background so dispatchers and customers can follow your delivery in real-time.",
        "NSCameraUsageDescription": "RENAX Rider uses your camera to capture proof-of-delivery photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020f09",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RENAX Rider tracks your location during deliveries so customers can follow their package in real-time."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020f09",
          "dark": {
            "backgroundColor": "#020f09"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
